#!/usr/bin/env bash
# Hutch — isolated CLI environments via Docker Compose.
#
# Three layers:
#   Image   — images/<name>/Dockerfile       (installed software)
#   Base    — bases/<name>.yml               (runtime definitions)
#   Profile — ~/.config/hutch/<name>         (BASE + COMMAND + DESCRIPTION)
#
# The workspace is always the current directory ($PWD).
# Profile state persists in the Docker volume <profile>_home.
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
IMAGES_DIR="$SCRIPT_DIR/images"
BASES_DIR="$SCRIPT_DIR/bases"
PROFILES_DIR="$HOME/.config/hutch"
CONFIG_FILE="$PROFILES_DIR/.config"

_usage() {
  cat <<EOF
usage:
  hutch <profile> [args...]          run the profile's default command in the current directory
  hutch shell <profile>              open an interactive shell in the profile

  hutch list [bases|images]          list profiles, available bases, or built images
  hutch build <base>                 build the image for a base
  hutch rebuild <base>               force rebuild the image (no cache)

  hutch new profile <name>           create a new profile and open it in the editor
  hutch new base <name>              create a new base and open it in the editor
  hutch new image <name>             create a new Dockerfile and open it in the editor

  hutch edit image|base|profile <name>   open an existing file in the editor

  hutch config editor [value]        get or set the preferred editor
  hutch config                       show all configuration

  hutch remove <profile>             delete the profile volume (keeps the profile file)

  hutch update                       update hutch to the latest version (preserves user files)
  hutch update --force               update and overwrite local modifications to hutch files

Examples:
  hutch work                         run claude in the current directory using the work profile
  hutch work login                   authenticate in the work profile
  hutch shell personal               interactive shell in the personal profile
  hutch edit profile work            edit the work profile file
  hutch edit base claude             edit the claude base
  hutch edit image claude            edit the claude Dockerfile
  hutch config editor nano           set nano as the preferred editor
  hutch build claude                 build hutch-claude:latest
  hutch list bases                   list bases and image status
EOF
}

# --- Config ---

_load_config() {
  HUTCH_EDITOR=""
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
}

_config_get() {
  local key="$1"
  _load_config
  case "$key" in
    editor) echo "${HUTCH_EDITOR:-}" ;;
    *) echo "Unknown config key: $key" >&2; exit 1 ;;
  esac
}

_config_set() {
  local key="$1" value="$2"
  mkdir -p "$PROFILES_DIR"
  touch "$CONFIG_FILE"
  case "$key" in
    editor)
      # Update or append
      if grep -q "^HUTCH_EDITOR=" "$CONFIG_FILE" 2>/dev/null; then
        sed -i "s|^HUTCH_EDITOR=.*|HUTCH_EDITOR=\"$value\"|" "$CONFIG_FILE"
      else
        echo "HUTCH_EDITOR=\"$value\"" >> "$CONFIG_FILE"
      fi
      echo "Editor set to: $value"
      ;;
    *) echo "Unknown config key: $key" >&2; exit 1 ;;
  esac
}

_config_show() {
  _load_config
  echo "Configuration ($CONFIG_FILE):"
  echo ""
  echo "  editor   ${HUTCH_EDITOR:-(not set — using \$VISUAL / \$EDITOR / auto-detect)}"
  echo ""
  echo "Environment overrides (take priority over config):"
  echo "  \$VISUAL  ${VISUAL:-  (not set)}"
  echo "  \$EDITOR  ${EDITOR:-  (not set)}"
}

# --- Editor ---

_open_editor() {
  local file="$1"
  _load_config
  # Priority: $VISUAL > $EDITOR > hutch config > auto-detect
  local editor="${VISUAL:-${EDITOR:-${HUTCH_EDITOR:-}}}"
  if [ -z "$editor" ]; then
    for e in sensible-editor nano vim vi; do
      if command -v "$e" &>/dev/null; then
        editor="$e"
        break
      fi
    done
  fi
  if [ -z "$editor" ]; then
    echo "No editor found. Set one with: hutch config editor <name>" >&2
    exit 1
  fi
  "$editor" "$file"
}

# --- Profiles ---

_load_profile() {
  local profile="$1"
  local config="$PROFILES_DIR/$profile"
  if [ ! -f "$config" ]; then
    echo "Profile '$profile' not found in $PROFILES_DIR" >&2
    echo "" >&2
    _list_profiles >&2
    exit 1
  fi
  BUILD="" BASE="" COMMAND="" DESCRIPTION=""
  # shellcheck source=/dev/null
  source "$config"
  # BASE defaults to "default" when not explicitly set
  BASE="${BASE:-default}"
}

_list_profiles() {
  echo "Profiles in $PROFILES_DIR:"
  echo ""
  local found=0
  for config in "$PROFILES_DIR"/*; do
    [ -f "$config" ] || continue
    local name
    name="$(basename "$config")"
    BUILD="" BASE="" COMMAND="" DESCRIPTION=""
    # shellcheck source=/dev/null
    source "$config"
    BASE="${BASE:-default}"
    local base_display vol_status
    base_display="$BASE${BUILD:+ (build: $BUILD)}"
    vol_status="$(docker volume inspect "${name}_home" &>/dev/null && echo "volume: exists" || echo "volume: new")"
    printf "  %-15s  %s\n" "$name" "$DESCRIPTION"
    printf "  %-15s  base: %-20s | cmd: %-10s | %s\n" "" "$base_display" "$COMMAND" "$vol_status"
    echo ""
    found=1
  done
  if [ "$found" -eq 0 ]; then echo "  (no profiles)"; fi
}

# --- Edit ---

_edit() {
  local type="${1:-}" name="${2:-}"
  if [ -z "$type" ] || [ -z "$name" ]; then
    echo "usage: hutch edit image|base|profile <name>" >&2
    exit 1
  fi
  local file
  case "$type" in
    image)
      file="$IMAGES_DIR/$name/Dockerfile"
      [ -f "$file" ] || { echo "Image '$name' not found: $file" >&2; exit 1; }
      ;;
    base)
      file="$BASES_DIR/$name.yml"
      [ -f "$file" ] || { echo "Base '$name' not found: $file" >&2; exit 1; }
      ;;
    profile)
      file="$PROFILES_DIR/$name"
      [ -f "$file" ] || { echo "Profile '$name' not found: $file" >&2; exit 1; }
      ;;
    *)
      echo "usage: hutch edit image|base|profile <name>" >&2
      exit 1
      ;;
  esac
  _open_editor "$file"
}

# --- Bases ---

_base_file() { echo "$BASES_DIR/$1.yml"; }

_list_bases() {
  echo "Bases in $BASES_DIR:"
  echo ""
  if [ -z "$(ls -A "$BASES_DIR" 2>/dev/null)" ]; then
    echo "  (no bases)"
    return
  fi
  for f in "$BASES_DIR"/*.yml; do
    [ -f "$f" ] || continue
    local name
    name="$(basename "$f" .yml)"
    printf "  %s\n" "$name"
    printf "    %s\n" "$f"
    echo ""
  done
}

_new_profile() {
  local name="${1:?usage: hutch new profile <name>}"
  local dest="$PROFILES_DIR/$name"
  mkdir -p "$PROFILES_DIR"
  if [ -f "$dest" ]; then
    echo "Profile '$name' already exists: $dest"
    _open_editor "$dest"
    return
  fi
  cat > "$dest" <<EOF
BUILD=""
BASE="default"
COMMAND=""
DESCRIPTION=""
EOF
  echo "Profile created: $dest"
  _open_editor "$dest"
}

_new_base() {
  local name="${1:?usage: hutch new base <name>}"
  local dest="$BASES_DIR/$name.yml"
  if [ -f "$dest" ]; then
    echo "Base '$name' already exists: $dest"
    _open_editor "$dest"
    return
  fi
  cat > "$dest" <<EOF
services:
  main:
    build:
      context: "\${HUTCH_IMAGES_DIR}/\${HUTCH_BUILD}"
    image: "\${HUTCH_IMAGE}"
    stdin_open: true
    tty: true
    user: "\${HUTCH_UID}:\${HUTCH_GID}"
    environment:
      - HOME=/home/user
    group_add:
      - "\${HUTCH_DOCKER_GID}"
    volumes:
      - profile_home:/home/user
      - "\${HUTCH_WORKSPACE}:/workspace"
      - /var/run/docker.sock:/var/run/docker.sock
    working_dir: /workspace

volumes:
  profile_home:
    name: "\${HUTCH_PROFILE}_home"
EOF
  echo "Base created: $dest"
  _open_editor "$dest"
}

# --- Images ---

_list_images() {
  echo "hutch-* images in Docker:"
  echo ""
  if ! docker images "hutch-*" --format "  {{.Repository}}:{{.Tag}}\t{{.Size}}\t{{.CreatedSince}}" 2>/dev/null | grep .; then
    echo "  (no images built)"
  fi
}

_new_image() {
  local name="${1:?usage: hutch new image <name>}"
  local dir="$IMAGES_DIR/$name"
  local dest="$dir/Dockerfile"
  mkdir -p "$dir"
  if [ -f "$dest" ]; then
    echo "Dockerfile '$name' already exists: $dest"
    _open_editor "$dest"
    return
  fi
  cat > "$dest" <<'EOF'
FROM debian:bookworm

RUN apt-get update && apt-get install -y \
    curl wget git vim nano less \
    procps jq \
    ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# Node.js via official NodeSource script
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# TODO: install the desired CLI
# RUN npm install -g @anthropic-ai/claude-code

# Home directory accessible to any UID (required for arbitrary user in docker compose)
RUN mkdir -p /home/user && chmod 777 /home/user
ENV HOME=/home/user
EOF
  echo "Dockerfile created: $dest"
  _open_editor "$dest"
}

_build_base() {
  local base="$1" no_cache="${2:-}"
  local base_file
  base_file="$(_base_file "$base")"
  if [ ! -f "$base_file" ]; then
    echo "Base '$base' not found: $base_file" >&2
    exit 1
  fi
  _export_env "_build"
  docker compose -f "$base_file" build $no_cache
}

# --- Runtime ---

_export_env() {
  local profile="$1"
  export HUTCH_PROFILE="$profile"
  export HUTCH_BUILD="${BUILD:-}"
  export HUTCH_IMAGE="hutch-${BUILD:-unknown}:latest"
  export HUTCH_WORKSPACE="$PWD"
  export HUTCH_IMAGES_DIR="$IMAGES_DIR"
  export HUTCH_UID="$(id -u)"
  export HUTCH_GID="$(id -g)"
  export HUTCH_DOCKER_GID="$(getent group docker 2>/dev/null | cut -d: -f3 || echo 999)"
}

_run() {
  local profile="$1" base_file="$2"
  shift 2
  _export_env "$profile"
  exec docker compose -f "$base_file" run --rm main "$@"
}

# --- Update ---

_update() {
  local force="${1:-}"
  cd "$SCRIPT_DIR"

  if ! git rev-parse --git-dir &>/dev/null; then
    echo "hutch was not installed via git — cannot update automatically." >&2
    echo "Re-run the install script to get the latest version:" >&2
    echo "  curl -fsSL https://raw.githubusercontent.com/guilhermewebdev/hutch/main/install.sh | bash" >&2
    exit 1
  fi

  echo "Fetching updates..."
  git fetch origin main --quiet

  local current remote
  current="$(git rev-parse HEAD)"
  remote="$(git rev-parse origin/main)"

  if [ "$current" = "$remote" ]; then
    echo "Already up to date."
    return
  fi

  echo ""
  echo "Changes to be applied:"
  git log --oneline HEAD..origin/main
  echo ""

  # Check for local modifications to tracked files
  local modified
  modified="$(git status --porcelain | grep -v '^??' || true)"

  if [ -n "$modified" ]; then
    echo "Local modifications to hutch files detected:"
    echo "$modified" | sed 's/^/  /'
    echo ""
    if [ "$force" = "--force" ]; then
      echo "Stashing local modifications (--force)..."
      git stash push --quiet -m "hutch update $(date +%Y-%m-%d)"
    else
      echo "These files may conflict with the update."
      echo "Options:"
      echo "  hutch update --force   stash your changes and update"
      echo "  git -C $SCRIPT_DIR pull   update manually"
      exit 1
    fi
  fi

  git pull --ff-only origin main

  # Re-run install to update symlink and add new default profiles
  # (existing user profiles in ~/.config/hutch/ are never overwritten)
  "$SCRIPT_DIR/install.sh"
}

# --- Entrypoint ---

cmd="${1:-}"

case "$cmd" in
  list)
    case "${2:-}" in
      bases)  _list_bases ;;
      images) _list_images ;;
      *)      _list_profiles ;;
    esac
    ;;

  new)
    case "${2:-}" in
      profile) _new_profile "${3:-}" ;;
      base)    _new_base "${3:-}" ;;
      image)   _new_image "${3:-}" ;;
      *) echo "usage: hutch new profile|base|image <name>" >&2; exit 1 ;;
    esac
    ;;

  edit)
    _edit "${2:-}" "${3:-}"
    ;;

  config)
    case "${2:-}" in
      editor)
        if [ -n "${3:-}" ]; then
          _config_set editor "$3"
        else
          _config_get editor
        fi
        ;;
      "") _config_show ;;
      *)  echo "usage: hutch config editor [value]" >&2; exit 1 ;;
    esac
    ;;

  build)
    _build_base "${2:?usage: hutch build <base>}"
    ;;

  rebuild)
    _build_base "${2:?usage: hutch rebuild <base>}" "--no-cache"
    ;;

  shell)
    profile="${2:?usage: hutch shell <profile>}"
    _load_profile "$profile"
    _run "$profile" "$(_base_file "$BASE")" bash
    ;;

  update)
    _update "${2:-}"
    ;;

  remove)
    profile="${2:?usage: hutch remove <profile>}"
    echo "Removing volume '${profile}_home'..."
    docker volume rm "${profile}_home" 2>/dev/null || echo "Volume not found."
    echo "Profile file at $PROFILES_DIR/$profile was kept."
    ;;

  "" | -h | --help)
    _usage
    ;;

  *)
    profile="$cmd"
    shift
    _load_profile "$profile"
    base_file="$(_base_file "$BASE")"
    if [ ! -f "$base_file" ]; then
      echo "Base '$BASE' not found: $base_file" >&2
      exit 1
    fi
    _run "$profile" "$base_file" "$COMMAND" "$@"
    ;;
esac
